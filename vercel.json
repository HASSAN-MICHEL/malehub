{
  "version": 2,

  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },

    {
      "src": "/uploads/(.*)",
      "dest": "/backend/uploads/$1"
    },

    {
      "src": "/assets/(.*)",
      "dest": "/front/dist/assets/$1"
    },

    {
      "src": "/(.*)",
      "dest": "/backend/server.js"
    }
  ]
}